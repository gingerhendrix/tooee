{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react",
    "customConditions": ["@tooee/source"],
    "types": ["bun"],
    "allowImportingTsExtensions": true
  }
}
